# ── Flask ────────────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret-key

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (development / small deployments):
DATABASE_URL=sqlite:///amanda.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── AI Backend (gRPC) ────────────────────────────────────────────────────────
GRPC_AI_BACKEND_HOST=localhost
GRPC_AI_BACKEND_PORT=8765

# ── Sessions ─────────────────────────────────────────────────────────────────
SESSION_TYPE=filesystem
# Use sqlalchemy for production (persists across restarts, works with multiple workers):
# SESSION_TYPE=sqlalchemy
SESSION_LIFETIME_MINUTES=60
SESSION_COOKIE_SAMESITE=Lax

# ── SocketIO ─────────────────────────────────────────────────────────────────
# threading = development (Python 3.12+)
# gevent    = production (required for WebSocket support via gunicorn)
SOCKETIO_ASYNC_MODE=gevent

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no spaces)
# Example production value: https://amanda-app.com,https://www.amanda-app.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# ── Email ────────────────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_DEFAULT_SENDER=noreply@amanda-app.com
# Set to False in production to actually send emails
MAIL_SUPPRESS_SEND=True

# ── Frontend ─────────────────────────────────────────────────────────────────
# Base URL used in email verification/reset links
FRONTEND_BASE_URL=https://amanda-app.com
